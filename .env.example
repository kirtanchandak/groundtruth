# ── Required ────────────────────────────────────────────────────────────────
# OpenAI API key — server-side only, never expose with NEXT_PUBLIC_.
OPENAI_API_KEY=sk-your-openai-api-key

# ── Optional: Model ──────────────────────────────────────────────────────────
# Recommended: gpt-4o-mini (fast, cheap — used by the Source Hunter agent)
# Falls back to gpt-4o-mini if unset.
OPENAI_MODEL=gpt-4o-mini

# ── Optional: Supabase persistence ──────────────────────────────────────────
# Without these, GroundTruth runs in local demo mode (in-memory, no database).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=sb_secret_your-secret-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
